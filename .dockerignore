# Keep the build context small and free of host-only state and secrets.
.git/
.venv/
.pytest_cache/
**/__pycache__/
*.pyc
.DS_Store
scratch/
dist/
build/
*.egg-info/

# The image is a generic runtime: only pylib/config get copied in. Jobs, data, and secrets
# are bind-mounted at runtime, never baked — keep them out of the build context entirely.
data/
job/
.env
**/.env
