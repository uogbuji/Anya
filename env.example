# anya deploy env — copy to .env and fill in (`.env` is gitignored).
#
# compose.yml reads these via ${VAR} interpolation. Two flows (see doc/DEPLOYMENT.md):
#   op run --env-file=.env -- docker compose up -d --build   # values are op:// reference URIs
#   docker compose up -d --build                             # values are concrete (Compose auto-reads ./.env)
#
# Set ONLY what your config.toml actually resolves to. Quote any value with spaces.

# --- Deploy knobs -----------------------------------------------------------
# Host path to the curated job dir bind-mounted at /app/job. Over a REMOTE Docker
# context this is resolved on the remote daemon, so use an ABSOLUTE path on that host
# (a relative ./job expands to your LOCAL absolute path, which won't exist remotely →
# empty mount → `anya serve` refuses to start). rsync your jobs there first.
ANYA_JOB_DIR=/srv/anya/job
# Seconds between scheduler ticks (default 86400 = 24h).
#ANYA_INTERVAL=86400
# Comma-separated phases to include this tick (default: default).
#ANYA_PHASES=default
# Comma-separated report recipients (overridable per invocation).
#ANYA_EMAIL_TO=you@example.com

# --- LLM backends (set only what config.toml resolves to) -------------------
OPENROUTER_API_KEY="op://Vault/OpenRouter API Key/credential"
#ANTHROPIC_API_KEY="op://Vault/Anthropic API Key/credential"

# --- Email delivery (default provider: resend) ------------------------------
ANYA_EMAIL_PROVIDER=resend
RESEND_API_KEY="op://Vault/Resend API Key/password"
RESEND_FROM="Anya Agent <anya-noreply@example.com>"
# Alternate provider (ANYA_EMAIL_PROVIDER=unosend):
#UNOSEND_API_KEY="op://Vault/Unosend API Key/credential"
#UNOSEND_FROM="Anya Agent <anya@example.com>"

# --- Optional crawl4ai fetcher service --------------------------------------
# crawl4ai is behind a Compose profile, so plain `up` skips it. Activate it either
# per-command (`docker compose --profile crawl up -d`) or persistently by uncommenting:
#COMPOSE_PROFILES=crawl
# Where anya reaches the service on the Compose network (default shown):
#CRAWL4AI_BASE_URL=http://crawl4ai:11235
